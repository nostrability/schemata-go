                  {
                    "$schema": "http://json-schema.org/draft-07/schema#",
                    "allOf": [
                      {
                        "allOf": [
                          {
                            "$schema": "http://json-schema.org/draft-07/schema#",
                            "type": "array",
                            "items": {
                              "type": "string"
                            },
                            "uniqueItems": false
                          }
                        ]
                      },
                      {
