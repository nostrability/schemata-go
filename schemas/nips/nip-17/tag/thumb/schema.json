{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "allOf": [
    {
      "allOf": [
        {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": false
        }
      ]
    },
    {
      "type": "array",
      "description": "Thumbnail URL for the encrypted media",
      "minItems": 2,
      "items": [
        {
          "const": "thumb"
        },
        {
          "type": "string",
          "format": "uri",
          "pattern": "^https?://",
          "errorMessage": "Thumbnail URL must start with http:// or https://"
        }
      ],
      "additionalItems": false
    }
  ],
  "$id": "https://nostrability.github.io/schemata/tag/thumb.json"
}