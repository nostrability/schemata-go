{
  "allOf": [
    {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "allOf": [
        {
          "allOf": [
            {
              "$schema": "http://json-schema.org/draft-07/schema#",
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": false
            }
          ]
        },
        {
          "type": "array",
          "minItems": 4,
          "items": [
            {
              "const": "client"
            },
            {
              "title": "name",
              "type": "string",
              "minLength": 1
            },
            {
              "title": "handler_address",
              "type": "string",
              "pattern": "^31990:[a-f0-9]{64}:.+$"
            },
            {
              "title": "relay_hint",
              "allOf": [
                {
                  "allOf": [
                    {
                      "$schema": "http://json-schema.org/draft-07/schema#",
                      "title": "relayUrl",
                      "type": "string",
                      "pattern": "^wss?://[a-zA-Z0-9._-]+(?::[0-9]+)?(?:/.*)?$",
                      "description": "WebSocket relay URL (ws:// or wss:// with valid hostname)",
                      "errorMessage": "must be a valid relay URL (ws:// or wss:// with valid hostname)"
                    }
                  ]
                }
              ]
            }
          ],
          "additionalItems": false
        }
      ]
    }
  ]
}