{
  "allOf": [
    {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "allOf": [
        {
          "allOf": [
            {
              "$schema": "http://json-schema.org/draft-07/schema#",
              "type": "array",
              "items": {
                "type": "string"
              },
              "uniqueItems": false
            }
          ]
        },
        {
          "type": "array",
          "description": "Recognized maintainers for the repository",
          "minItems": 2,
          "items": [
            {
              "const": "maintainers"
            },
            {
              "allOf": [
                {
                  "$schema": "http://json-schema.org/draft-07/schema#",
                  "type": "string",
                  "pattern": "^[a-f0-9]{64}$"
                }
              ]
            }
          ],
          "additionalItems": {
            "allOf": [
              {
                "$schema": "http://json-schema.org/draft-07/schema#",
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              }
            ]
          }
        }
      ]
    }
  ]
}